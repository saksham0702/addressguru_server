              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.slug) {",
                  "  pm.collectionVariables.set('slug', res.data.slug);",
                  "  console.log('Slug saved:', res.data.slug);",
