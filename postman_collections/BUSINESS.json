              "path": ["business", "get-features", "665f1a2b3c4d5e6f7a8b9c0d"],
              "query": [
                {
                  "key": "subcategory_id",
                  "value": "665f1a2b3c4d5e6f7a8b9c0e",
                  "disabled": true,
                  "description": "Optional — filter features by subcategory"
                }
