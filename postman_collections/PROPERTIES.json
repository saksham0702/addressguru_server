{
  "info": {
    "name": "Property Listings API",
    "_postman_id": "property-listings-collection",
    "description": "Complete API collection for Property Listings — create, update steps, fetch, and delete.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "listing_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "listing_slug",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "POST – Create Listing (Step 1)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const res = pm.response.json();",
              "if (res.data?.id) {",
              "  pm.collectionVariables.set('listing_id', res.data.id);",
              "}",
              "if (res.data?.slug) {",
              "  pm.collectionVariables.set('listing_slug', res.data.slug);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "category_id",       "value": "664f1e2b3a4c5d6e7f8a9b0c", "type": "text" },
            { "key": "sub_category_id",   "value": "664f1e2b3a4c5d6e7f8a9b0d", "type": "text" },
            { "key": "city_id",           "value": "664f1e2b3a4c5d6e7f8a9b0e", "type": "text" },
            { "key": "title",             "value": "Luxury 5 Marla House for Sale in DHA",  "type": "text" },
            { "key": "description",       "value": "A beautifully designed 5 marla house located in DHA Phase 6 with modern interiors.", "type": "text" },
            { "key": "purpose",           "value": "sale",       "type": "text", "description": "sale | rent | lease" },
            { "key": "price_amount",      "value": "25000000",   "type": "text" },
            { "key": "price_currency",    "value": "AED",        "type": "text" },
            { "key": "price_negotiable",  "value": "false",      "type": "text" },
            { "key": "price_period",      "value": "one-time",   "type": "text", "description": "one-time | monthly | yearly | weekly" },
            { "key": "area_size",         "value": "5",          "type": "text" },
            { "key": "area_unit",         "value": "marla",      "type": "text", "description": "marla | kanal | sqft | sqm | sqyd" },
            { "key": "payments",          "value": "664f1e2b3a4c5d6e7f8a9b10", "type": "text" },
            { "key": "additional_fields", "value": "[{\"field_id\":\"664f1e2b3a4c5d6e7f8a9b11\",\"value\":\"5\"}]", "type": "text" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/property-listings/create-listing",
          "host": ["{{base_url}}"],
          "path": ["property-listings", "create-listing"]
        }
      }
    },
    {
      "name": "PUT – Step 1: Property Info",
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "category_id",       "value": "664f1e2b3a4c5d6e7f8a9b0c", "type": "text" },
            { "key": "sub_category_id",   "value": "664f1e2b3a4c5d6e7f8a9b0d", "type": "text" },
            { "key": "city_id",           "value": "664f1e2b3a4c5d6e7f8a9b0e", "type": "text" },
            { "key": "title",             "value": "Updated Luxury 5 Marla House",           "type": "text" },
            { "key": "description",       "value": "Updated description for the property.",  "type": "text" },
            { "key": "purpose",           "value": "sale",       "type": "text" },
            { "key": "price_amount",      "value": "26000000",   "type": "text" },
            { "key": "price_currency",    "value": "AED",        "type": "text" },
            { "key": "price_negotiable",  "value": "true",       "type": "text" },
            { "key": "price_period",      "value": "one-time",   "type": "text" },
            { "key": "area_size",         "value": "5",          "type": "text" },
            { "key": "area_unit",         "value": "marla",      "type": "text" },
            { "key": "payments",          "value": "664f1e2b3a4c5d6e7f8a9b10", "type": "text" },
            { "key": "additional_fields", "value": "[{\"field_id\":\"664f1e2b3a4c5d6e7f8a9b11\",\"value\":\"5\"}]", "type": "text" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/property-listings/update-listing/{{listing_id}}/step/1",
          "host": ["{{base_url}}"],
          "path": ["property-listings", "update-listing", "{{listing_id}}", "step", "1"]
        }
      }
    },
    {
      "name": "PUT – Step 2: Media (Images)",
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "images", "type": "file", "src": [], "description": "Upload up to 20 images" },
            { "key": "images", "type": "file", "src": [], "description": "Upload up to 20 images" },
            { "key": "images", "type": "file", "src": [], "description": "Upload up to 20 images" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/property-listings/update-listing/{{listing_id}}/step/2",
          "host": ["{{base_url}}"],
          "path": ["property-listings", "update-listing", "{{listing_id}}", "step", "2"]
        }
      }
    },
    {
      "name": "PUT – Step 3: Contact Details",
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "name",                "value": "Ahmed Raza",    "type": "text" },
            { "key": "email",               "value": "ahmed@example.com", "type": "text" },
            { "key": "country_code",        "value": "92",            "type": "text" },
            { "key": "mobile_number",       "value": "3001234567",    "type": "text" },
            { "key": "alt_country_code",    "value": "92",            "type": "text" },
            { "key": "second_mobile_number","value": "3019876543",    "type": "text" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/property-listings/update-listing/{{listing_id}}/step/3",
          "host": ["{{base_url}}"],
          "path": ["property-listings", "update-listing", "{{listing_id}}", "step", "3"]
        }
      }
    },
    {
      "name": "PUT – Step 4: Social & Links",
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "website_link", "value": "https://myproperty.com",                        "type": "text" },
            { "key": "video_link",   "value": "https://youtube.com/watch?v=abc123",             "type": "text" },
            { "key": "facebook",     "value": "https://facebook.com/myproperty",               "type": "text" },
            { "key": "instagram",    "value": "https://instagram.com/myproperty",              "type": "text" },
            { "key": "youtube",      "value": "https://youtube.com/channel/myproperty",        "type": "text" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/property-listings/update-listing/{{listing_id}}/step/4",
          "host": ["{{base_url}}"],
          "path": ["property-listings", "update-listing", "{{listing_id}}", "step", "4"]
        }
      }
    },
    {
      "name": "PUT – Step 5: SEO",
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "seo_title",       "value": "Buy 5 Marla House in DHA Lahore – Best Price", "type": "text" },
            { "key": "seo_description", "value": "Find the best 5 marla house for sale in DHA Phase 6 Lahore at an affordable price.", "type": "text" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/property-listings/update-listing/{{listing_id}}/step/5",
          "host": ["{{base_url}}"],
          "path": ["property-listings", "update-listing", "{{listing_id}}", "step", "5"]
        }
      }
    },
    {
      "name": "PUT – Step 6: Plan & Publish",
      "request": {
        "method": "PUT",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "plan_id", "value": "664f1e2b3a4c5d6e7f8a9b20", "type": "text" }
          ]
        },
        "url": {
          "raw": "{{base_url}}/property-listings/update-listing/{{listing_id}}/step/6",
          "host": ["{{base_url}}"],
          "path": ["property-listings", "update-listing", "{{listing_id}}", "step", "6"]
        }
      }
    },
    {
      "name": "GET – All Listings (Paginated + Filters)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/property-listings/get-all-listings?page=1&limit=10&purpose=sale&city_id=664f1e2b3a4c5d6e7f8a9b0e&min_price=1000000&max_price=50000000",
          "host": ["{{base_url}}"],
          "path": ["property-listings", "get-all-listings"],
          "query": [
            { "key": "page",         "value": "1" },
            { "key": "limit",        "value": "10" },
            { "key": "purpose",      "value": "sale",                        "description": "sale | rent | lease" },
            { "key": "city_id",      "value": "664f1e2b3a4c5d6e7f8a9b0e",   "description": "MongoDB ObjectId of the city" },
            { "key": "min_price",    "value": "1000000",                     "description": "Minimum price filter" },
            { "key": "max_price",    "value": "50000000",                    "description": "Maximum price filter" },
            { "key": "property_type","value": "",                            "description": "Optional property type filter", "disabled": true },
            { "key": "furnishing",   "value": "",                            "description": "Optional furnishing filter",     "disabled": true },
            { "key": "bedrooms",     "value": "",                            "description": "Optional bedrooms filter",       "disabled": true }
          ]
        }
      }
    },
    {
      "name": "GET – Single Listing by Slug",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/property-listings/get-listing-by-slug/{{listing_slug}}",
          "host": ["{{base_url}}"],
          "path": ["property-listings", "get-listing-by-slug", "{{listing_slug}}"]
        }
      }
    },
    {
      "name": "DELETE – Delete Listing",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/property-listings/delete-listing/{{listing_id}}",
          "host": ["{{base_url}}"],
          "path": ["property-listings", "delete-listing", "{{listing_id}}"]
        }
      }
    }
  ]
}