        {
          "name": "[Admin] List All Claims",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/claims?page=1&limit=20&status=pending&listingModel=BusinessListing",
              "host": ["{{baseUrl}}"],
              "path": ["admin","claims"],
              "query": [
                { "key": "page",         "value": "1" },
                { "key": "limit",        "value": "20" },
                { "key": "status",       "value": "pending",         "description": "pending | approved | rejected" },
                { "key": "listingModel", "value": "BusinessListing", "description": "BusinessListing | Job | Property | Marketplace" }
              ]
            }
          },
          "response": []
        },

        {
          "name": "[Admin] Approve Claim",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/claims/{{claimId}}", "host": ["{{baseUrl}}"], "path": ["admin","claims","{{claimId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\",\n  \"adminNote\": \"Ownership documents verified. Claim approved.\"\n}"
            }
          },
          "response": []
        },

        {
          "name": "[Admin] Reject Claim",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/admin/claims/{{claimId}}", "host": ["{{baseUrl}}"], "path": ["admin","claims","{{claimId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\",\n  \"adminNote\": \"Insufficient proof of ownership provided.\"\n}"
            }
          },
          "response": []
        }

      ]
