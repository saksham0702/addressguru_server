{
  "info": {
    "name": "Classified Backend API",
    "description": "Complete API collection for Classified project — BusinessListing, Job, Property, Marketplace with Enquiry, Claim, Report, Review features.",
    "_postman_id": "classified-backend-v2-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",  "value": "http://localhost:5000/api", "type": "string" },
    { "key": "token",    "value": "YOUR_JWT_TOKEN_HERE",        "type": "string" },
    { "key": "adminToken","value": "YOUR_ADMIN_JWT_TOKEN_HERE", "type": "string" },

    { "key": "businessSlug",    "value": "achievers-dream-chemistry",  "type": "string" },
    { "key": "jobSlug",         "value": "senior-react-developer-lahore","type": "string" },
    { "key": "propertySlug",    "value": "3bhk-flat-dha-karachi",      "type": "string" },
    { "key": "marketplaceSlug", "value": "iphone-14-pro-max-256gb",    "type": "string" },

    { "key": "enquiryId",  "value": "", "type": "string" },
    { "key": "claimId",    "value": "", "type": "string" },
    { "key": "reportId",   "value": "", "type": "string" },
    { "key": "reviewId",   "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "📋 Enquiry",
      "item": [

        {
          "name": "Send Enquiry — Business",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/business/{{businessSlug}}/enquiry", "host": ["{{baseUrl}}"], "path": ["business","{{businessSlug}}","enquiry"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Ahmed Khan\",\n  \"email\": \"ahmed@example.com\",\n  \"countryCode\": 92,\n  \"mobileNumber\": 3001234567,\n  \"message\": \"I would like to get more information about your chemistry tuition services.\"\n}"
            }
          },
          "response": []
        },

        {
          "name": "Send Enquiry — Job",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/job/{{jobSlug}}/enquiry", "host": ["{{baseUrl}}"], "path": ["job","{{jobSlug}}","enquiry"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Sara Ali\",\n  \"email\": \"sara@example.com\",\n  \"countryCode\": 92,\n  \"mobileNumber\": 3009876543,\n  \"message\": \"I am interested in this job position. Please share more details.\"\n}"
            }
          },
          "response": []
        },

        {
          "name": "Send Enquiry — Property",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/property/{{propertySlug}}/enquiry", "host": ["{{baseUrl}}"], "path": ["property","{{propertySlug}}","enquiry"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Zain Malik\",\n  \"email\": \"zain@example.com\",\n  \"countryCode\": 92,\n  \"mobileNumber\": 3111234567,\n  \"message\": \"Is this property still available? I want to schedule a visit.\"\n}"
            }
          },
          "response": []
        },

        {
          "name": "Send Enquiry — Marketplace",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/marketplace/{{marketplaceSlug}}/enquiry", "host": ["{{baseUrl}}"], "path": ["marketplace","{{marketplaceSlug}}","enquiry"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Hina Shah\",\n  \"email\": \"hina@example.com\",\n  \"countryCode\": 92,\n  \"mobileNumber\": 3331234567,\n  \"message\": \"Is the price negotiable? Can I see the item?\"\n}"
            }
          },
          "response": []
        },

        {
          "name": "Get Enquiries for Listing (Owner/Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/business/{{businessSlug}}/enquiries?page=1&limit=20&status=new",
              "host": ["{{baseUrl}}"],
              "path": ["business","{{businessSlug}}","enquiries"],
              "query": [
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "20" },
                { "key": "status", "value": "new", "description": "new | read | replied" }
              ]
            }
          },
          "response": []
        },

        {
          "name": "Update Enquiry Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/enquiries/{{enquiryId}}", "host": ["{{baseUrl}}"], "path": ["enquiries","{{enquiryId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"read\"\n}",
              "options": { "raw": { "language": "json" } }
            }
          },
          "response": []
        }

      ]
    },

