<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Welcome to AddressGuru UAE</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">
  <style>
    body {
      margin: 0;
      padding: 0;
      background-color: #f6f7fb;
      font-family: 'Poppins', sans-serif;
      color: #333333;
    }

    .wrapper {
      width: 100%;
      background-color: #f6f7fb;
      padding: 40px 0;
    }

    .container {
      max-width: 880px;
      background: #ffffff;
      margin: auto;
      border-radius: 14px;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
      overflow: hidden;
    }

    .header {
      background: linear-gradient(135deg, #f7941d, #ffb347);
      text-align: center;
      padding: 40px 20px;
      color: #fff;
    }

    .header img {
      width: 160px;
      margin-bottom: 15px;
    }

    .header h1 {
      font-size: 26px;
      margin: 10px 0 0;
      font-weight: 600;
      letter-spacing: 0.5px;
    }

    .content {
      padding: 35px 30px;
      font-size: 16px;
      line-height: 1.7;
    }

    .content h2 {
      font-size: 20px;
      color: #f7941d;
      margin-bottom: 10px;
      font-weight: 600;
    }

    .highlight-box {
      background: #fff9f2;
      border: 1px solid #ffe0b3;
      border-radius: 10px;
      padding: 20px;
      margin-top: 25px;
      box-shadow: 0 2px 6px rgba(247, 148, 29, 0.1);
    }

    .highlight-box p {
      margin: 8px 0;
      font-size: 15px;
    }

    .highlight-box strong {
      color: #333;
    }

    .cta-button {
      display: inline-block;
      background: linear-gradient(135deg, #f7941d, #ffb347);
      color: #fff !important;
      text-decoration: none;
      padding: 14px 30px;
      border-radius: 50px;
      font-weight: 600;
      margin-top: 30px;
      transition: all 0.3s ease;
    }

    .cta-button:hover {
      background: linear-gradient(135deg, #ff9e35, #ffb347);
      box-shadow: 0 4px 10px rgba(247, 148, 29, 0.3);
    }

    .footer {
      background-color: #fafafa;
      padding: 25px 20px;
      text-align: center;
      font-size: 13px;
      color: #777;
      border-top: 1px solid #eee;
    }

    .footer a {
      color: #f7941d;
      text-decoration: none;
      font-weight: 500;
    }

    .footer a:hover {
      text-decoration: underline;
    }

    .divider {
      height: 1px;
      background-color: #eee;
      margin: 30px 0;
    }

    @media (max-width: 480px) {
      .content {
        padding: 25px 20px;
      }

      .header h1 {
        font-size: 22px;
      }

      .cta-button {
        display: block;
        width: 100%;
        text-align: center;
        box-sizing: border-box;
      }
    }
  </style>
</head>

<body>
  <div class="wrapper">
    <div class="container">
      <!-- Header -->
      <div class="header">
        <img src="https://www.addressguru.in/images/logopng.png" alt="AddressGuru Logo">
        <h1>Welcome to AddressGuru UAE!</h1>
      </div>

      <!-- Content -->
      <div class="content">
        <p>Hi <strong>{{name}}</strong>,</p>
        <p>
          We’re thrilled to have you onboard! 🎉
          Thank you for signing up with <strong>AddressGuru UAE</strong> — your one-stop platform to discover, list, and
          connect with local businesses.
        </p>

        <p>
          Need help or have questions? Our support team is always here to assist.
          <a href="mailto:support@addressguru.ae">Contact Support</a>
        </p>

        <p>Welcome aboard,</p>
        <p><strong>The AddressGuru UAE Team</strong></p>
      </div>

      <!-- Footer -->
      <div class="footer">
        &copy; {{year}} <strong>AddressGuru UAE</strong>. All rights reserved.<br>
        <a href="https://www.addressguru.ae">www.addressguru.ae</a> | <a
          href="mailto:support@addressguru.ae">support@addressguru.ae</a>
      </div>
    </div>
  </div>
</body>

</html>