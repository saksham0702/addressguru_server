<html>
  <head>
    <title>Change Your Email Address - ElevateU</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@600&family=Roboto&display=swap" rel="stylesheet" />
    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #ffffff;
        font-family: 'Roboto', Arial, sans-serif;
        color: #000000;
      }
      .container {
        max-width: 600px;
        margin: auto;
        background-color: #f9f9f9;
        border: 1px solid #e0e0e0;
        border-radius: 8px;
        padding: 40px 30px;
      }
      .header {
        text-align: center;
        padding-bottom: 30px;
      }
      .header h1 {
        font-family: 'Nunito', Arial, sans-serif;
        font-size: 26px;
        margin: 0;
        color: #000000;
      }
      .content {
        font-size: 16px;
        line-height: 1.6;
        color: #333333;
      }
      .otp-box {
        background-color: #98CE00;
        color: #000000;
        font-family: monospace;
        padding: 14px;
        margin: 20px 0;
        border-radius: 6px;
        text-align: center;
        font-weight: bold;
        font-size: 24px;
        letter-spacing: 4px;
      }
      .footer {
        text-align: center;
        margin-top: 40px;
        font-size: 13px;
        color: #777777;
      }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="header">
        <h1>Email Change Request</h1>
      </div>

      <div class="content">
        <p>Hello {{email}},</p>

        <p>We received a request to change the email address associated with your ElevateU account.</p>

        <p>To confirm this change, please use the OTP code below. This code is valid for 10 minutes.</p>

        <div class="otp-box">
          {{otp}}
        </div>

        <p>If you did not request to change your email, please ignore this message. No changes will be made to your account.</p>
      </div>

      <div class="footer">
        &copy; 2025 ElevateU Support. All rights reserved.
      </div>
    </div>
  </body>
</html>
